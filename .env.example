# ─── Supabase ────────────────────────────────────────────────────────────────
# Public URL is safe to expose; the service role key MUST stay server-side.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...

# ─── Xtime API (reverse-engineered) ──────────────────────────────────────────
# Captured from a logged-in DevTools session at consumer.xtime.com.

# API host that serves /xws/rest. Stable.
XTIME_BASE_URL=https://x10con.xtime.com

# Origin/Referer Xtime expects. Always consumer.xtime.com.
XTIME_CONSUMER_ORIGIN=https://consumer.xtime.com

# Short numeric session token (e.g. 7778139113). Refresh by reloading the
# consumer scheduler page when calls start returning 401/403. Lifetime is
# typically tens of minutes — minutes-to-hours depending on tenant.
XTIME_TOKEN_ID=7778139113

# Country code Xtime requires on every call.
XTIME_COUNTRY_CODE=US

# Dealer's internal Xtime ID, e.g. xtm20220211107xx1. Captured from the URL
# path of any /xws/rest/.../dealer/<this>/... call.
XTIME_DEALER_ID=xtm20220211107xx1

# ─── reCAPTCHA v3 solver ─────────────────────────────────────────────────────
# Xtime gates every API call behind Google reCAPTCHA v3. Tokens live ~2 minutes
# and are single-use, so we mint a fresh one per outbound call.
#
# Mode: 'manual' (paste token, demo only) | 'capsolver' | 'twocaptcha'
RECAPTCHA_MODE=capsolver

# Public site key for Xtime's consumer scheduler. Found in the page source of
# https://consumer.xtime.com/ (search for `sitekey`). Stable across sessions.
RECAPTCHA_SITE_KEY=6Lc...

# The page URL Google associates with the token. Must match what Xtime uses.
RECAPTCHA_PAGE_URL=https://consumer.xtime.com/

# v3 action label. Optional; Xtime's exact action names aren't documented but
# 'submit' / 'verify' usually pass.
RECAPTCHA_ACTION=submit

# ── Mode 'manual' only ──
# Paste a fresh gRecaptchaResponse here (from DevTools Network tab) for local
# testing. Tokens expire ~2 min after Google's JS issues them.
XTIME_RECAPTCHA_TOKEN=

# ── Mode 'capsolver' only ──
# https://capsolver.com → Dashboard → API key. ~$1 per 1000 v3 tokens.
CAPSOLVER_API_KEY=CAP-xxxxxxxxxxxxxxxx

# ── Mode 'twocaptcha' only ──
# https://2captcha.com → API key. ~$2-3 per 1000 v3 tokens.
TWOCAPTCHA_API_KEY=

# ─── Retell AI ───────────────────────────────────────────────────────────────
# Used to verify inbound webhook signatures from Retell.
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx
RETELL_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
